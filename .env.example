# ---------------------------------------------------------------------------
# Copy to .env and adjust. .env is gitignored; .env.example is committed.
# Values below assume the docker-compose services (postgres/redis/piston) are
# reachable on localhost (host-based `bun dev`). Inside the compose network the
# web/worker containers get service-name hosts injected by docker-compose.yml.
# ---------------------------------------------------------------------------

NODE_ENV="development"

# Postgres
DATABASE_URL="postgresql://contest:contest@localhost:5544/contest?schema=public"

# Redis (BullMQ queue + rate-limit counters + SSE pub/sub)
REDIS_URL="redis://localhost:6379"

# Self-hosted Piston execution engine
PISTON_API_URL="http://localhost:2000"

# --- Secrets (generate strong random values in real deployments) ---
# Used to HMAC-sign CSRF tokens bound to a session. `openssl rand -hex 32`
APP_SECRET="dev-only-insecure-change-me-0000000000000000000000000000000000000000"

# --- Session ---
SESSION_COOKIE_NAME="contest_session"
SESSION_TTL_SECONDS="43200"          # 12h

# --- Rate limits ---
RATE_LIMIT_RUN_SUBMIT_SECONDS="5"    # 1 execution per N seconds per user
RATE_LIMIT_LOGIN_MAX="10"            # max login attempts
RATE_LIMIT_LOGIN_WINDOW_SECONDS="60"

# --- Execution safety ---
MAX_OUTPUT_BYTES="65536"             # cap Piston stdout/stderr persisted per test case

# --- Display ---
CONTEST_TIMEZONE="Asia/Kolkata"
